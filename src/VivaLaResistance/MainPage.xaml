<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:VivaLaResistance.ViewModels"
             x:Class="VivaLaResistance.MainPage"
             x:DataType="viewmodels:MainViewModel"
             Title="Resistor Scanner">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Camera Preview Container -->
        <Grid Grid.Row="0" 
              BackgroundColor="#1a1a2e"
              x:Name="CameraContainer">
            
            <!-- Camera initializing state -->
            <VerticalStackLayout 
                VerticalOptions="Center" 
                HorizontalOptions="Center"
                Spacing="20"
                IsVisible="{Binding IsCameraInitializing}">
                
                <Label 
                    Text="📷"
                    FontSize="64"
                    HorizontalOptions="Center"
                    SemanticProperties.Description="Camera icon" />
                
                <Label 
                    Text="Starting Camera…"
                    FontSize="24"
                    TextColor="White"
                    HorizontalOptions="Center"
                    SemanticProperties.Description="Starting camera" />
                
                <Label 
                    Text="Point camera at a resistor to detect its value"
                    FontSize="14"
                    TextColor="#888888"
                    HorizontalOptions="Center"
                    SemanticProperties.Description="Instructions for using the app" />
            </VerticalStackLayout>

            <!-- Permission denied state -->
            <VerticalStackLayout 
                VerticalOptions="Center" 
                HorizontalOptions="Center"
                Spacing="20"
                Padding="32"
                IsVisible="{Binding IsPermissionDenied}">
                
                <Label 
                    Text="🔒"
                    FontSize="64"
                    HorizontalOptions="Center"
                    SemanticProperties.Description="Lock icon" />
                
                <Label 
                    Text="Camera Access Required"
                    FontSize="24"
                    TextColor="White"
                    HorizontalOptions="Center"
                    SemanticProperties.HeadingLevel="Level1" />
                
                <Label 
                    Text="Camera access is required to use this app. Please enable in Settings."
                    FontSize="14"
                    TextColor="#888888"
                    HorizontalOptions="Center"
                    HorizontalTextAlignment="Center"
                    SemanticProperties.Description="Camera permission required message" />
                
                <Button 
                    Text="Open Settings"
                    BackgroundColor="#e94560"
                    TextColor="White"
                    FontSize="16"
                    FontAttributes="Bold"
                    CornerRadius="8"
                    Padding="24,12"
                    Margin="0,16,0,0"
                    Clicked="OnOpenSettingsClicked"
                    SemanticProperties.Hint="Opens system settings to enable camera permission" />
            </VerticalStackLayout>

            <!-- AR Overlay Layer for detected resistors -->
            <AbsoluteLayout x:Name="OverlayLayer" />

        </Grid>

        <!-- Bottom Status Bar -->
        <Grid Grid.Row="1" 
              BackgroundColor="#16213e" 
              Padding="16">
            
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Status Text -->
            <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                <Label 
                    Text="{Binding StatusText}"
                    FontSize="16"
                    TextColor="White"
                    SemanticProperties.Description="{Binding StatusText}" />
                
                <Label 
                    Text="{Binding TrialStatusText}"
                    FontSize="12"
                    TextColor="#888888"
                    IsVisible="{Binding ShowTrialStatus}"
                    SemanticProperties.Description="{Binding TrialStatusText}" />
            </VerticalStackLayout>

            <!-- Detected Count -->
            <Frame Grid.Column="1"
                   BackgroundColor="#0f3460"
                   CornerRadius="20"
                   Padding="12,8"
                   BorderColor="Transparent"
                   IsVisible="{Binding HasDetections}">
                
                <Label 
                    Text="{Binding DetectionCountText}"
                    FontSize="14"
                    TextColor="White"
                    SemanticProperties.Description="{Binding DetectionCountText}" />
            </Frame>

        </Grid>

    </Grid>

</ContentPage>